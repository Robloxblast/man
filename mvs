-- =============================================
-- TEAM CHECK HELPER
-- Reads PlayerGui.Main.MainGameFrame.PlayersFrame
-- TeamBlueFrame / TeamRedFrame to determine team.
-- =============================================

local function getLocalTeam()
    local gui = localPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil end
    local main = gui:FindFirstChild("Main")
    if not main then return nil end
    local mgf = main:FindFirstChild("MainGameFrame")
    if not mgf then return nil end
    local pf = mgf:FindFirstChild("PlayersFrame")
    if not pf then return nil end

    local blueFrame = pf:FindFirstChild("TeamBlueFrame")
    local redFrame  = pf:FindFirstChild("TeamRedFrame")

    if blueFrame and blueFrame:FindFirstChild(localPlayer.Name) then
        return "Blue"
    elseif redFrame and redFrame:FindFirstChild(localPlayer.Name) then
        return "Red"
    end
    return nil
end

local function getPlayerTeam(plr)
    local gui = localPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil end
    local main = gui:FindFirstChild("Main")
    if not main then return nil end
    local mgf = main:FindFirstChild("MainGameFrame")
    if not mgf then return nil end
    local pf = mgf:FindFirstChild("PlayersFrame")
    if not pf then return nil end

    local blueFrame = pf:FindFirstChild("TeamBlueFrame")
    local redFrame  = pf:FindFirstChild("TeamRedFrame")

    if blueFrame and blueFrame:FindFirstChild(plr.Name) then
        return "Blue"
    elseif redFrame and redFrame:FindFirstChild(plr.Name) then
        return "Red"
    end
    return nil
end

local function isTeammate(plr)
    local myTeam  = getLocalTeam()
    local plrTeam = getPlayerTeam(plr)
    if not myTeam or not plrTeam then return false end
    return myTeam == plrTeam
end

