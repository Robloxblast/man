local wasInMatch = false

local function onMatchStarted()
    task.wait(1) -- let teams fully populate
    if hitboxEnabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr == localPlayer then continue end
            resetHitbox(plr)
            if hitboxTeamCheck and isTeammate(plr) then continue end
            applyHitbox(plr)
        end
    end
    if espEnabled then
        clearAllESP()
    end
end

local function onMatchEnded()
    if hitboxEnabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr == localPlayer then continue end
            resetHitbox(plr)
            applyHitbox(plr)
        end
    end
    if espEnabled then
        clearAllESP()
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        local currentlyInMatch = isInMatch()
        if currentlyInMatch ~= wasInMatch then
            wasInMatch = currentlyInMatch
            if currentlyInMatch then
                onMatchStarted()
            else
                onMatchEnded()
            end
        end
    end
end)

