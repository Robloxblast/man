-- SILENT AIM
-- =============================================

local hookSupported = typeof(hookmetamethod) == "function"

if not hookSupported then
    Rayfield:Notify({
        Title = "Silent Aim Unavailable",
        Content = "Your executor doesn't support hookmetamethod so Silent Aim has been hidden. Camera Lock still works normally.",
        Duration = 8,
        Image = 4483362458,
    })
else
    AimbotTab:CreateParagraph({
        Title = "Silent Aim",
        Content = "Redirects your mouse hit to the closest enemy in your FOV."
    })

    AimbotTab:CreateToggle({
        Name = "Silent Aim",
        CurrentValue = false,
        Flag = "SilentAim",
        Callback = function(v)
            silentAimEnabled = v
            updateFOVCircle()
        end,
    })

    AimbotTab:CreateToggle({
        Name = "Silent Aim Wall Check",
        CurrentValue = false,
        Flag = "SilentAimWallCheck",
        Callback = function(v)
            silentWallCheck = v
        end,
    })

    AimbotTab:CreateSlider({
        Name = "Silent Aim FOV",
        Range = {10, 500},
        Increment = 1,
        Suffix = " px",
        CurrentValue = aimbotFOV,
        Flag = "SilentAimFOV",
        Callback = function(v)
            aimbotFOV = v
        end,
    })

    local originalMethod
    originalMethod = hookmetamethod(game, "__index", newcclosure(function(self, key)
        if not checkcaller() and self:IsA("Mouse") and key == "Hit" then
            if silentAimEnabled then
                local target = getClosestPlayerInFOV(silentWallCheck)
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    return target.Character.HumanoidRootPart.CFrame
                end
            end
        end
        return originalMethod(self, key)
    end))
end

