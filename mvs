-- HITBOX EXPANDER
-- =============================================

MainTab:CreateParagraph({
    Title = "Hitbox Expander INFO",
    Content = "Expands Hitbox of all enemies. Team Check prevents expanding teammates. Re-applies on when teammates/enemies die."
})

local hitboxEnabled      = false
local hitboxSize         = 5
local hitboxTransparency = 0.5
local hitboxTeamCheck    = true
local hitboxConnections  = {}

local function applyHitbox(plr)
    if not hitboxEnabled then return end
    if not plr.Character then return end
    if hitboxTeamCheck and isTeammate(plr) then return end

    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
hrp.Transparency = hitboxTransparency
hrp.CanCollide = false
hrp.Massless = false
end

local function resetHitbox(plr)
    if not plr.Character then return end
    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.Size         = Vector3.new(2, 2, 1)
    hrp.Transparency = 1
    hrp.Massless     = false
end

local function connectPlayer(plr)
    if plr == localPlayer then return end

    -- Apply on current character
    if plr.Character then
        applyHitbox(plr)
    end

    -- Re-apply on respawn
    if hitboxConnections[plr] then
        hitboxConnections[plr]:Disconnect()
    end
    hitboxConnections[plr] = plr.CharacterAdded:Connect(function(newChar)
        task.wait(0.5) -- wait for character to load
        applyHitbox(plr)
    end)
end

local function disconnectPlayer(plr)
    if hitboxConnections[plr] then
        hitboxConnections[plr]:Disconnect()
        hitboxConnections[plr] = nil
    end
    resetHitbox(plr)
end

