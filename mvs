-- ── Wall check helper ─────────────────────────

local function hasLineOfSight(targetHRP)
    local origin    = camera.CFrame.Position
    local direction = (targetHRP.Position - origin)
    local ray       = Ray.new(origin, direction)
    local hit       = workspace:FindPartOnRayWithIgnoreList(ray, {localPlayer.Character, targetHRP.Parent})
    -- if nothing was hit, or what was hit is the target itself, we have LOS
    if not hit then return true end
    return hit:IsDescendantOf(targetHRP.Parent)
end

-- ── Closest player in FOV ─────────────────────

local function getClosestPlayerInFOV(useWallCheck)
    local closestPlayer = nil
    local closestDist   = math.huge
    local center        = camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end
        if not plr.Character then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        local screenPos, visible = camera:WorldToViewportPoint(hrp.Position)
        if not visible then continue end

        local pos2D          = Vector2.new(screenPos.X, screenPos.Y)
        local distFromCenter = (pos2D - center).Magnitude

        if distFromCenter <= aimbotFOV and distFromCenter < closestDist then
            -- wall check
            if useWallCheck and not hasLineOfSight(hrp) then continue end
            closestDist   = distFromCenter
            closestPlayer = plr
        end
    end

    return closestPlayer
end

-- ── FOV Circle visibility helper ─────────────

local function updateFOVCircle()
    fovCircle.Visible = silentAimEnabled or cameraLockEnabled
end

