MainTab:CreateParagraph({
    Title = "ESP INFO",
    Content = "Creates an ESP on players. Choose between Box, Tracer, or Highlight mode. Toggle Include Teammates to show teammates too."
})

local espEnabled       = false
local espTeammates     = false
local espMode          = "Box"
local espEnemyColor    = Color3.fromRGB(255, 0, 0)
local espTeammateColor = Color3.fromRGB(0, 255, 0)

-- Drawing-based
local espBoxes   = {}
local espTracers = {}
-- Highlight-based
local espHighlights = {}

-- ── Box helpers ───────────────────────────────

local function createESPBox(plr)
    if espBoxes[plr] then return end
    local box = Drawing.new("Square")
    box.Visible      = false
    box.Color        = espEnemyColor
    box.Thickness    = 1
    box.Filled       = false
    box.Transparency = 1
    espBoxes[plr] = box
end

local function removeESPBox(plr)
    if espBoxes[plr] then
        espBoxes[plr]:Remove()
        espBoxes[plr] = nil
    end
end

-- ── Tracer helpers ────────────────────────────

local function createESPTracer(plr)
    if espTracers[plr] then return end
    local line = Drawing.new("Line")
    line.Visible      = false
    line.Color        = espEnemyColor
    line.Thickness    = 1
    line.Transparency = 1
    espTracers[plr] = line
end

local function removeESPTracer(plr)
    if espTracers[plr] then
        espTracers[plr]:Remove()
        espTracers[plr] = nil
    end
end

-- ── Highlight helpers ─────────────────────────

local function createESPHighlight(plr)
    if espHighlights[plr] then return end
    if not plr.Character then return end
    local hl = Instance.new("Highlight")
    hl.Name              = "IYESPHighlight"
    hl.FillColor         = espEnemyColor
    hl.OutlineColor      = espEnemyColor
    hl.FillTransparency  = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode         = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent            = plr.Character
    espHighlights[plr] = hl
end

local function removeESPHighlight(plr)
    if espHighlights[plr] then
        espHighlights[plr]:Destroy()
        espHighlights[plr] = nil
    end
end

-- ── Clear all ESP ─────────────────────────────

local function clearAllESP()
    for plr, _ in pairs(espBoxes)      do removeESPBox(plr)       end
    for plr, _ in pairs(espTracers)    do removeESPTracer(plr)     end
    for plr, _ in pairs(espHighlights) do removeESPHighlight(plr)  end
end

-- ── RenderStepped loop ────────────────────────

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _, box  in pairs(espBoxes)   do box.Visible  = false end
        for _, line in pairs(espTracers) do line.Visible = false end
        for _, hl   in pairs(espHighlights) do hl.Enabled = false end
        return
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end

        local teammate = isTeammate(plr)
        local showThis = espTeammates or not teammate
        local col      = teammate and espTeammateColor or espEnemyColor

        -- Hide inactive modes
        if espBoxes[plr]      then espBoxes[plr].Visible      = false end
        if espTracers[plr]    then espTracers[plr].Visible     = false end
        if espHighlights[plr] then espHighlights[plr].Enabled  = false end

        if not showThis      then continue end
        if not plr.Character then continue end

        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        -- ── BOX ──
        if espMode == "Box" then
            createESPBox(plr)
            local box = espBoxes[plr]

            local topPos,    topVis    = camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
            local bottomPos, bottomVis = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            if not topVis and not bottomVis then
                box.Visible = false
                continue
            end

            local height = math.abs(topPos.Y - bottomPos.Y)
            local width  = height * 0.6
            box.Size     = Vector2.new(width, height)
            box.Position = Vector2.new(topPos.X - width / 2, topPos.Y)
            box.Color    = col
            box.Visible  = true

        -- ── TRACER ──
        elseif espMode == "Tracer" then
            createESPTracer(plr)
            local line = espTracers[plr]

            local screenPos, visible = camera:WorldToViewportPoint(hrp.Position)
            if not visible then
                line.Visible = false
                continue
            end

            local center = camera.ViewportSize
            line.From    = Vector2.new(center.X / 2, center.Y)
            line.To      = Vector2.new(screenPos.X, screenPos.Y)
            line.Color   = col
            line.Visible = true

        -- ── HIGHLIGHT ──
        elseif espMode == "Highlight" then
            -- Re-parent if character changed
            if not espHighlights[plr] or espHighlights[plr].Parent ~= plr.Character then
                removeESPHighlight(plr)
                createESPHighlight(plr)
            end
            local hl = espHighlights[plr]
            if hl then
                hl.FillColor    = col
                hl.OutlineColor = col
                hl.Enabled      = true
            end
        end
    end
end)

-- Handle character respawns for Highlight mode
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(0.5)
        if espEnabled and espMode == "Highlight" then
            removeESPHighlight(plr)
            createESPHighlight(plr)
        end
    end)
end)

for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= localPlayer then
        plr.CharacterAdded:Connect(function()
            task.wait(0.5)
            if espEnabled and espMode == "Highlight" then
                removeESPHighlight(plr)
                createESPHighlight(plr)
            end
        end)
    end
end

