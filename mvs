local function hasLineOfSight(targetHRP)
    local origin = camera.CFrame.Position
    local direction = targetHRP.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {localPlayer.Character, targetHRP.Parent}
    local ray = workspace:Raycast(origin, direction, params)
    return not ray
end

-- Separate functions for silent aim and camera lock
-- so they each use their own mode independently
local function getClosestPlayerSilent()
    local closestPlayer = nil
    local closestDist   = math.huge

    local origin
    if silentAimFOVMode == "Follow Mouse" then
        origin = Vector2.new(mouse.X, mouse.Y)
    else
        origin = camera.ViewportSize / 2
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end
        if not plr.Character then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end
        local screenPos, visible = camera:WorldToViewportPoint(hrp.Position)
        if not visible then continue end
        local pos2D = Vector2.new(screenPos.X, screenPos.Y)
        local dist  = (pos2D - origin).Magnitude
        if dist <= aimbotFOV and dist < closestDist then
            if silentWallCheck and not hasLineOfSight(hrp) then continue end
            closestDist   = dist
            closestPlayer = plr
        end
    end

    return closestPlayer
end

local function getClosestPlayerCamera()
    local closestPlayer = nil
    local closestDist   = math.huge
    local center        = camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end
        if not plr.Character then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end
        local screenPos, visible = camera:WorldToViewportPoint(hrp.Position)
        if not visible then continue end
        local pos2D = Vector2.new(screenPos.X, screenPos.Y)
        local dist  = (pos2D - center).Magnitude
        if dist <= aimbotFOV and dist < closestDist then
            if cameraWallCheck and not hasLineOfSight(hrp) then continue end
            closestDist   = dist
            closestPlayer = plr
        end
    end

    return closestPlayer
end

