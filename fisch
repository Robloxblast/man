local function cleanEventText(rawText)
    local cleaned = rawText:gsub("<[^>]+>", "")
    cleaned = cleaned:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
    return cleaned
end

local function isEventMessage(text)
    if string.find(text, "%[Event%]") then return true end
    if string.find(text, "%[Global Event%]") then return true end
    if string.find(text, "%[Cultist Lair%]") then return true end
    if string.find(text, "%[Mossjaw Hunt%]") then return true end
    if string.find(text, "%[System%]") then return false end
    return false
end

local function getAllActiveEvents()
    local activeEvents = {}
    pcall(function()
        local StarterGui = game:GetService("StarterGui")
