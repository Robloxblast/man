function SettingsConfig:Save()
    self.Data.SavedPlaces = getgenv()[SAVED_PLACES_KEY] or {}
    originalSave(self)
end

local originalLoad = SettingsConfig.Load
function SettingsConfig:Load()
    local data = originalLoad(self)
    if data and data.SavedPlaces then
        getgenv()[SAVED_PLACES_KEY] = data.SavedPlaces
        savedCoordinates = {}
        loadPlacesFromConfig()
        refreshSavedPlacesDropdown()
    end
    return data
end


