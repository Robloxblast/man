            for _, descendant in ipairs(chat:GetDescendants()) do
                if (descendant:IsA("TextLabel") or descendant:IsA("TextButton")) and descendant.Visible then
                    local textContent = descendant.Text
                    if isEventMessage(textContent) and textContent ~= "" then
                        local cleanText = cleanEventText(textContent)
                        table.insert(activeEvents, cleanText)
                    end
                end
            end
        end
    end)
    return activeEvents
end

