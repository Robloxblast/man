local function getLureValue()
    local playerFolder = Workspace:FindFirstChild(player.Name)
    if not playerFolder then return nil end
    
    local rod = getCurrentRod()
    if rod then
        local lure = playerFolder:FindFirstChild(rod.Name)
        if lure and lure:FindFirstChild("values") then
            local v = lure.values:FindFirstChild("lure")
            if v then return v.Value end
        end
    end
    
    for _, obj in ipairs(playerFolder:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("values") then
            local v = obj.values:FindFirstChild("lure")
            if v then return v.Value end
        end
    end
    
    return nil
end

local function monitorLureFastMode()
    local lastFired = false
    
    while autoFinish do
        local value = getLureValue()
        
        if value then
            if value >= 100 and not lastFired then
                lastFired = true
                
                task.delay(3.5, function()
                    local newValue = getLureValue()
                    if newValue and newValue >= 100 then
                        fireFinishRemote()
                    end
                end)
                
            elseif value < 100 then
                lastFired = false
            end
        end
        
        task.wait(0.1)
    end
end

