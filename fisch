local function getCurrentRod()
    local folder = Workspace:FindFirstChild(player.Name)
    if not folder then return nil, nil end
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChild("events") then
            local ev = child.events
            if ev:FindFirstChild("castAsync") then
                return child, "castAsync"
            end
            if ev:FindFirstChild("cast") then
                return child, "cast"
            end
            for _, r in ipairs(ev:GetChildren()) do
                if r:IsA("RemoteEvent") or r:IsA("RemoteFunction") then
                    return child, r.Name
                end
            end
        end
    end
    return nil, nil
end

local function tryCast(rod, methodName, argsTable)
    if not rod or not rod:FindFirstChild("events") then return end
    local remote = rod.events:FindFirstChild(methodName)
    if not remote then return end
    if remote:IsA("RemoteFunction") then
        pcall(function() remote:InvokeServer(unpack(argsTable)) end)
    else
        pcall(function() remote:FireServer(unpack(argsTable)) end)
    end
end

