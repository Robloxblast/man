      GrabKeyFromSite = false, -- If this is true, set Key below to the RAW site you would like Rayfield to get the key from
      Key = {"Hello"} -- List of keys that the system will accept, can be RAW file links (pastebin, github, etc.) or simple strings ("hello", "key22")
   }
})

local Tab = Window:CreateTab("Main", "rewind")

local workType = "odd_jobs"
local autoWork = false


local Toggle = Tab:CreateToggle({
   Name = "Auto Work",
   CurrentValue = false,
   Flag = "AutoWorkToggle",
   Callback = function(Value)
      autoWork = Value

      while autoWork do
         local args = {
            "DoWork",
            workType
         }

         game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("Req"):FireServer(unpack(args))
         task.wait(1)
      end
   end,
})



local Dropdown = Tab:CreateDropdown({
   Name = "Work Type",
   Options = {
      "Odd Jobs",
      "Cursed Object Patrol",
      "Curse Exorcism",
      "Cursed Relic Hunts",
      "Jujutsu Missions",
      "Special Grade Hunts",
      "Elder Contracts",
      "Culling Game Rounds"
   },
   CurrentOption = {"Odd Jobs"},
   MultipleOptions = false,
   Flag = "WorkDropdown",
   Callback = function(Options)
      local v = Options[1]

      if v == "Odd Jobs" then
         workType = "odd_jobs"
      elseif v == "Cursed Object Patrol" then
         workType = "patrol"
      elseif v == "Curse Exorcism" then
         workType = "exorcism"
      elseif v == "Cursed Relic Hunts" then
         workType = "relic_hunt"
      elseif v == "Jujutsu Missions" then
         workType = "mission"
      elseif v == "Special Grade Hunts" then
         workType = "grade_hunt"
      elseif v == "Elder Contracts" then
         workType = "contract"
      elseif v == "Culling Game Rounds" then
         workType = "game_round"
      end
   end,
})


local autoTrain = false
local trainOptions = {
   Level = false,
   Energy = false
}

local Toggle = Tab:CreateToggle({
   Name = "Auto Train",
   CurrentValue = false,
   Flag = "AutoTrainToggle",
   Callback = function(Value)
      autoTrain = Value

      while autoTrain do
         if trainOptions.Level then
            local args = {
               "TrainLevel"
            }
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("Req"):FireServer(unpack(args))
         end

         if trainOptions.Energy then
            local args = {
               "TrainEnergy"
            }
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("Req"):FireServer(unpack(args))
         end

         task.wait(0.05)
      end
   end,
})

local Dropdown = Tab:CreateDropdown({
   Name = "Train Options",
   Options = {"Level","Energy"},
   CurrentOption = {},
   MultipleOptions = true,
   Flag = "TrainDropdown",
   Callback = function(Options)
      trainOptions.Level = false
      trainOptions.Energy = false

      for _,v in pairs(Options) do
         if v == "Level" then
            trainOptions.Level = true
         elseif v == "Energy" then
            trainOptions.Energy = true
         end
      end
   end,
})


