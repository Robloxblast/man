-- Macro keybind input
MacroKeyInput = Tab:CreateInput({
    Name = "Macro Keybind",
    CurrentValue = "",
    PlaceholderText = "Press key...",
    RemoveTextAfterFocusLost = false,
    Flag = "MacroKeyInput",
    Callback = function(text)
        local selected = MacroDropdown.CurrentOption[1]
        local macro = selected and Macros[selected]
        if macro then
            local keyStr = tostring(text or ""):upper()

            -- convert numbers 0-9 to Enum names
            if NumberKeyMap[keyStr] then
                keyStr = NumberKeyMap[keyStr]
            end

            local keyEnum = Enum.KeyCode[keyStr]
            if keyEnum then
                macro.key = keyStr
                macro.keyEnum = keyEnum
            else
                warn("Invalid keybind: "..text)
            end
        end
    end,
})

-- Add new macro
MacroAddButton = Tab:CreateButton({
    Name = "Add Macro",
    Callback = function()
        local seq = tostring(MacroInput.CurrentValue or ""):upper()
        local keyStr = tostring(MacroKeyInput.CurrentValue or ""):upper()

        if NumberKeyMap[keyStr] then
            keyStr = NumberKeyMap[keyStr]
        end

        local keyEnum = Enum.KeyCode[keyStr]

        if seq ~= "" and keyEnum then
            local macro = {
                key = keyStr,
                keyEnum = keyEnum,
                sequence = seq
            }

            table.insert(Macros, macro)

            -- refresh dropdown
            RefreshMacroDropdown()

            -- select the newly added macro safely
            local name = macro.key.." = "..macro.sequence
            task.wait()
            MacroDropdown:Set({name})

        else
            warn("Invalid macro input")
        end
    end,
})

-- Delete macro
MacroDeleteButton = Tab:CreateButton({
    Name = "Delete Macro",
    Callback = function()
        local selected = MacroDropdown.CurrentOption[1]
        if selected then
            -- find the macro in the array
            for i = #Macros, 1, -1 do
                local macro = Macros[i]
                local name = (macro.key or "").." = "..(macro.sequence or "")
                if name == selected then
                    table.remove(Macros, i)
                    break
                end
            end
            RefreshMacroDropdown()
        end

        MacroInput:Set("")
        MacroKeyInput:Set("")
    end,
})
-- -------------------------
-- Hotkey execution
-- -------------------------
UserInputService.InputBegan:Connect(function(input, g)
    if g then return end
    for _, macro in ipairs(Macros) do
        if input.KeyCode == macro.keyEnum then
            for i = 1, #macro.sequence do
                local char = macro.sequence:sub(i,i)
                local keyEnum = Enum.KeyCode[char]
                if keyEnum then
                    VirtualInputManager:SendKeyEvent(true, keyEnum, false, game)
                    VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
                end
            end
        end
    end
end)

