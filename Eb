-- Heartbeat logic
RunService.Heartbeat:Connect(function()
    if not toggle then return end

    local animList = {}
    if modeSelection == "Shootings" then
        for _, id in ipairs(shootingAnims) do animList[id] = true end
    elseif modeSelection == "Dunks" then
        for _, id in ipairs(dunkAnims) do animList[id] = true end
    elseif modeSelection == "Floaters" then
        for _, id in ipairs(floaterAnims) do animList[id] = true end
    else
        for _, id in ipairs(shootingAnims) do animList[id] = true end
        for _, id in ipairs(dunkAnims) do animList[id] = true end
        for _, id in ipairs(floaterAnims) do animList[id] = true end
    end

    local closestPlayer
    local shortestDist = 20
    local detectedAnimId

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            if table.find(ignoredPlayers, plr.Name) then continue end
            local dist = (LP.Character.HumanoidRootPart.Position - plr.Character.HumanoidRootPart.Position).Magnitude
            if dist <= shortestDist then
                local hum = plr.Character:FindFirstChild("Humanoid")
                local animator = hum and hum:FindFirstChildOfClass("Animator")
                if animator then
                    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                        local animId = tonumber(track.Animation.AnimationId:match("%d+"))
                        if animList[animId] then
                            closestPlayer = plr
                            shortestDist = dist
                            detectedAnimId = animId
                            break
                        end
                    end
                end
            end
        end
    end

    if closestPlayer then
        local jumpDelay = delayShooting
        if detectedAnimId then
            if table.find(dunkAnims, detectedAnimId) then
                jumpDelay = delayDunk
            elseif table.find(floaterAnims, detectedAnimId) then
                jumpDelay = delayFloater
            end

            local meter = closestPlayer.Character.HumanoidRootPart:FindFirstChild("Meter")
            local meterValid = meter and meter:FindFirstChild("Fill") and meter.Fill.Size.X.Scale >= meterPercent

            if not meterCheck or (meterCheck and meterValid) then
                jumpedTracks[detectedAnimId] = true
                task.spawn(function()
                    task.wait(jumpDelay)
                    vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                    task.wait()
                    vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                end)
            end
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        local hum = plr.Character and plr.Character:FindFirstChild("Humanoid")
        local animator = hum and hum:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                local animId = tonumber(track.Animation.AnimationId:match("%d+"))
                jumpedTracks[animId] = nil
            end
        end
    end
end)

