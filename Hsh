-- helper to get color from ColorSequence at position (0￯﾿ﾢ￯ﾾﾀ￯ﾾﾓ1)
local function getColorAt(sequence, t)
    local keypoints = sequence.Keypoints
    for i = 1, #keypoints - 1 do
        local k1, k2 = keypoints[i], keypoints[i+1]
        if t >= k1.Time and t <= k2.Time then
            local alpha = (t - k1.Time) / (k2.Time - k1.Time)
            local r = k1.Value.R + (k2.Value.R - k1.Value.R) * alpha
            local g = k1.Value.G + (k2.Value.G - k1.Value.G) * alpha
            local b = k1.Value.B + (k2.Value.B - k1.Value.B) * alpha
            return Color3.new(r, g, b)
        end
    end
    return keypoints[#keypoints].Value
end

