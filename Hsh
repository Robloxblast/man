rs.RenderStepped:Connect(function()
    if not autoWorkout then return end

    local arrowPos = arrow.AbsolutePosition.X + (arrow.AbsoluteSize.X / 2)
    local barStart = perfect.AbsolutePosition.X
    local barEnd = barStart + perfect.AbsoluteSize.X

    if arrowPos >= barStart and arrowPos <= barEnd then
        local relPos = (arrowPos - barStart) / perfect.AbsoluteSize.X
        local color = getColorAt(gradient.Color, relPos)

        if color.G > 0.7 and color.R < 0.5 then
            if not clicked then
                vim:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                vim:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                clicked = true
            end
        else
            clicked = false
        end
    else
        clicked = false
    end
end)




