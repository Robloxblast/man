local tog = false
local savedStates = {}

local function setCollision(char, state)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if not savedStates[part] then
                savedStates[part] = part.CanCollide
            end
            part.CanCollide = state
        end
    end
end

local function restoreCollision(char)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and savedStates[part] ~= nil then
            part.CanCollide = savedStates[part]
            savedStates[part] = nil
        end
    end
end

local function updateAll()
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= lp and plr.Character then
            if tog then
                setCollision(plr.Character, false)
            else
                restoreCollision(plr.Character)
            end
        end
    end
end

