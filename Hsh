-- Controls
local tog = false
local selectedTypes = {"Dribble"}

-- Separate speed values for each category
local dribbleSpeed = 1
local shootSpeed = 1
local dunkSpeed = 1

-- Get all selected IDs
local function getSelectedIds()
    local ids = {}
    for _, typeName in ipairs(selectedTypes) do
        if typeName == "Dribble" then
            for _, id in ipairs(dribbleIds) do table.insert(ids, id) end
        elseif typeName == "Shooting" then
            for _, id in ipairs(shootIds) do table.insert(ids, id) end
        elseif typeName == "Dunking" then
            for _, id in ipairs(dunkIds) do table.insert(ids, id) end
        end
    end
    return ids
end

-- Determine which speed value applies
local function getSpeedForId(id)
    if table.find(dribbleIds, id) then
        return dribbleSpeed
    elseif table.find(shootIds, id) then
        return shootSpeed
    elseif table.find(dunkIds, id) then
        return dunkSpeed
    end
    return 1
end

-- Apply speed changes
local function apply(hum)
    if not tog then return end
    local ids = getSelectedIds()
    for _, track in ipairs(hum.Animator:GetPlayingAnimationTracks()) do
        local id = string.match(track.Animation.AnimationId, "%d+")
        if table.find(ids, id) then
            track:AdjustSpeed(getSpeedForId(id))
        end
    end
end

-- Hook animation start
local function setup(char)
    local hum = char:WaitForChild("Humanoid")
    hum.Animator.AnimationPlayed:Connect(function(track)
        local ids = getSelectedIds()
        local id = string.match(track.Animation.AnimationId, "%d+")
        if table.find(ids, id) then
            track:AdjustSpeed(tog and getSpeedForId(id) or 1)
        end
    end)
end

