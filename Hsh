run.Heartbeat:Connect(function()
    if not toggled or not enabled then return end

    local closestPlayer, closestDist = nil, studs
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= lp and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            if enableTeamCheck and plr.Team == lp.Team then
                continue
            end

            -- ￯﾿ﾢ￯ﾾﾜ￯ﾾﾅ Ignore player completely if they are playing a screen animation
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local ignore = false
            if hum then
                for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                    local id = string.match(track.Animation.AnimationId, "%d+")
                    if getgenv().IgnoreScreens and ignoredAnims[id] then
                        ignore = true
                        break
                    end
                end
            end
            if ignore then
                continue
            end

            local dist = (plr.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if dist <= closestDist then
                closestPlayer = plr
                closestDist = dist
            end
        end
    end

    if closestPlayer and closestPlayer.Character then
        local hum = closestPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                local id = string.match(track.Animation.AnimationId, "%d+")
                if (not getgenv().IgnoreScreens or not ignoredAnims[id]) 
                   and (animIDs[id] or (blockChanceEnabled and id == "14057562857" and math.random(0, 100) <= blockChance)) then
                    task.wait(delay)
                    vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                    task.wait()
                    vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    break
                end
            end
        end
    end
end)




