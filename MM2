local function removeBox(plr)
    if espBoxes[plr] then espBoxes[plr]:Remove() espBoxes[plr] = nil end
end
local function removeTracer(plr)
    if espTracers[plr] then espTracers[plr]:Remove() espTracers[plr] = nil end
end
local function removeHighlight(plr)
    if espHighlights[plr] then espHighlights[plr]:Destroy() espHighlights[plr] = nil end
end
local function removeText(plr)
    if espTexts[plr] then espTexts[plr]:Remove() espTexts[plr] = nil end
end
local function clearESP(plr)
    removeBox(plr) removeTracer(plr) removeHighlight(plr) removeText(plr)
end
local function clearAllESP()
    for plr in pairs(espBoxes)      do removeBox(plr)       end
    for plr in pairs(espTracers)    do removeTracer(plr)     end
    for plr in pairs(espHighlights) do removeHighlight(plr)  end
    for plr in pairs(espTexts)      do removeText(plr)       end
end

local function clearGunDropESP()
    for k, v in pairs(gunDropBoxes) do
        v:Destroy()
        gunDropBoxes[k] = nil
    end
end

local function addGunDropHighlight(obj)
    if not espGunDrop then return end
    if not obj:IsA("BasePart") or obj.Name ~= "GunDrop" then return end
    if gunDropBoxes[obj] then return end
    local hl               = Instance.new("Highlight")
    hl.FillColor           = Color3.fromRGB(0, 200, 255)
    hl.OutlineColor        = Color3.fromRGB(0, 200, 255)
    hl.FillTransparency    = 0.4
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent              = obj
    gunDropBoxes[obj]      = hl
end

local function removeGunDropHighlight(obj)
    if gunDropBoxes[obj] then
        gunDropBoxes[obj]:Destroy()
        gunDropBoxes[obj] = nil
    end
end

workspace.DescendantAdded:Connect(function(obj)
    addGunDropHighlight(obj)
end)

workspace.DescendantRemoving:Connect(function(obj)
    removeGunDropHighlight(obj)
end)

