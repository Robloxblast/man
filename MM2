local collectEnabled = false
local selectedMethod = "Instant TP"
local collectThread = nil

local function findCoinContainer()
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc.Name == "CoinContainer" then
            return desc
        end
    end
    return nil
end

local function getValidCoins(container)
    local coins = {}
    for _, child in ipairs(container:GetChildren()) do
        if child.Name == "Coin_Server" and child:IsA("BasePart") then
            local coinVisual = child:FindFirstChild("CoinVisual")
            if coinVisual then
                local mainCoin = coinVisual:FindFirstChild("MainCoin")
                if mainCoin and mainCoin.Transparency == 0 then
                    table.insert(coins, child)
                end
            end
        end
    end
    return coins
end

local function tweenToPosition(targetCFrame, callback)
    local tween = TweenService:Create(
        rootPart,
        TweenInfo.new(0.08, Enum.EasingStyle.Linear),
        {CFrame = targetCFrame}
    )
    tween:Play()
    tween.Completed:Connect(callback)
end

local function startCollecting()
    collectThread = task.spawn(function()
        while collectEnabled do
            local container = findCoinContainer()
            if container then
                local coins = getValidCoins(container)
                for _, coin in ipairs(coins) do
                    if not collectEnabled then break end
                    if not coin.Parent then continue end

                    -- Re-check MainCoin transparency before collecting
                    local coinVisual = coin:FindFirstChild("CoinVisual")
                    local mainCoin = coinVisual and coinVisual:FindFirstChild("MainCoin")
                    if not mainCoin or mainCoin.Transparency ~= 0 then continue end

                    if selectedMethod == "Instant TP" then
                        rootPart.CFrame = coin.CFrame
                        task.wait(0.05)
                    elseif selectedMethod == "Tween" then
                        local done = false
                        tweenToPosition(coin.CFrame, function()
                            done = true
                        end)
                        local timeout = 0
                        repeat
                            task.wait()
                            timeout += 1
                        until done or not collectEnabled or timeout > 100
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

local function stopCollecting()
    collectEnabled = false
    if collectThread then
        task.cancel(collectThread)
        collectThread = nil
    end
end

