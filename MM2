RunService.RenderStepped:Connect(function()
    -- Player ESP
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == lp then continue end

        -- hide all first
if espBoxes[plr]      then espBoxes[plr].Visible         = false end
        if espTracers[plr]    then espTracers[plr].Visible        = false end
        if espHighlights[plr] then espHighlights[plr].Enabled     = false end
        if espTexts[plr]      then espTexts[plr].Visible          = false end

        if not espEnabled then continue end
        if not plr.Character then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        local role = getRole(plr)
        local col  = roleColors[role]

        if espModes["Box"] then
            if not espBoxes[plr] then
                local b        = Drawing.new("Square")
                b.Visible      = false
                b.Filled       = false
                b.Thickness    = 2
                b.Transparency = 1
                espBoxes[plr]  = b
            end
            local b          = espBoxes[plr]
            local tp, tv     = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
            local bp2, bv    = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
            if tv or bv then
                local h    = math.abs(tp.Y - bp2.Y)
                local w    = h * 0.6
                b.Size     = Vector2.new(w, h)
                b.Position = Vector2.new(tp.X - w / 2, tp.Y)
                b.Color    = col
                b.Visible  = true
            end
        else
            if espBoxes[plr] then espBoxes[plr].Visible = false end
        end

        if espModes["Tracer"] then
            if not espTracers[plr] then
                local l         = Drawing.new("Line")
                l.Visible       = false
                l.Thickness     = 2
                l.Transparency  = 1
                espTracers[plr] = l
            end
            local l         = espTracers[plr]
            local sp, vis   = cam:WorldToViewportPoint(hrp.Position)
            if vis then
                l.From    = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
                l.To      = Vector2.new(sp.X, sp.Y)
                l.Color   = col
                l.Visible = true
            else
                l.Visible = false
            end
        else
            if espTracers[plr] then espTracers[plr].Visible = false end
        end

        if espModes["Highlight"] then
            if not espHighlights[plr] or espHighlights[plr].Parent ~= plr.Character then
                removeHighlight(plr)
                createHighlight(plr, col)
            end
            local hl = espHighlights[plr]
            if hl then
                hl.FillColor    = col
                hl.OutlineColor = col
                hl.Enabled      = true
            end
        else
            if espHighlights[plr] then espHighlights[plr].Enabled = false end
        end

        if espModes["Text"] then
            if not espTexts[plr] then
                local t       = Drawing.new("Text")
                t.Visible     = false
                t.Size        = 16
                t.Center      = true
                t.Outline     = true
                espTexts[plr] = t
            end
            local t         = espTexts[plr]
            local sp, vis   = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.5, 0))
            if vis then
                t.Position = Vector2.new(sp.X, sp.Y)
                t.Text     = plr.Name
                t.Color    = col
                t.Visible  = true
            else
                t.Visible = false
            end
        else
            if espTexts[plr] then espTexts[plr].Visible = false end
        end
    end
end)

