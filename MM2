-- Auto Shoot + Manual Shoot Murder
local AutoShootEnabled = false
local AutoShootThread  = nil

local function hasGun()
    local char = LocalPlayer.Character
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    return (char and char:FindFirstChild("Gun")) or (bp and bp:FindFirstChild("Gun"))
end

local function getShootRemote()
    local char = LocalPlayer.Character
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    local gun  = (char and char:FindFirstChild("Gun")) or (bp and bp:FindFirstChild("Gun"))
    if not gun then return nil end
    return gun:FindFirstChild("Shoot")
end

local function getMurderer()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not isAlive(p) then continue end
        if isMurderer(p) then return p end
    end
    return nil
end

local function shootMurderer()
    if not hasGun() then
        Rayfield:Notify({
            Title   = "Auto Shoot",
            Content = "You don't have a Gun!",
            Duration = 3,
            Image   = 4483362458,
        })
        return
    end

    local murderer = getMurderer()
    if not murderer then
        Rayfield:Notify({
            Title   = "Auto Shoot",
            Content = "No murderer found.",
            Duration = 3,
            Image   = 4483362458,
        })
        return
    end

    local hrp    = getRootPart(murderer)
    local head   = getHead(murderer)
    local myHRP  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local remote = getShootRemote()

    if not hrp or not head or not myHRP or not remote then return end

    -- TP behind murderer
    local behindCFrame = hrp.CFrame * CFrame.new(0, 0, 3.5)
    myHRP.CFrame = behindCFrame

    task.wait(0.08)

    -- Fire shoot remote at their head
    remote:FireServer(
        myHRP.CFrame,
        CFrame.new(head.Position)
    )
end

local function startAutoShoot()
    AutoShootThread = task.spawn(function()
        while AutoShootEnabled do
            shootMurderer()
            task.wait(0.5)
        end
    end)
end

local function stopAutoShoot()
    AutoShootEnabled = false
    if AutoShootThread then
        task.cancel(AutoShootThread)
        AutoShootThread = nil
    end
end

