-- ============================================================
-- LOS CHECK
-- ============================================================

local function hasLOS(hrp)
    local origin = cam.CFrame.Position
    local dir    = hrp.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {lp.Character, hrp.Parent}
    return not workspace:Raycast(origin, dir, params)
end

-- ============================================================
-- SILENT AIM
-- ============================================================

local silentWallCheck    = false
local silentLockedPlayer = nil

local function getClosestSilent()
    local best, bestDist = nil, math.huge
    local origin
    if silentFOVMode == "Follow Mouse" then
        origin = Vector2.new(mouse.X, mouse.Y)
    else
        origin = cam.ViewportSize / 2
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if not isValidTarget(plr) then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local sp, vis = cam:WorldToViewportPoint(hrp.Position)
        if not vis then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - origin).Magnitude
        if dist <= aimbotFOV and dist < bestDist then
            if silentWallCheck and not hasLOS(hrp) then continue end
            bestDist = dist
            best     = plr
        end
    end
    return best
end

