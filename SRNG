local function getBestZone()
    local best = 0
    for i = 1, 33 do
        local zone = zones:FindFirstChild(tostring(i))
        if not zone then continue end
        local back = zone:FindFirstChild("Gate") and zone.Gate:FindFirstChild("Back")
        if back and not back.CanCollide then best = i + 1 end
    end
    -- always return at least 1 so zone 1 can be purchased after rebirth
    return math.max(best, 1)
end

local function getCurrentPurchasableZone()
    -- find the first zone that has a locked gate (CanCollide = true)
    for i = 1, 33 do
        local zone = zones:FindFirstChild(tostring(i))
        if not zone then continue end
        local gate = zone:FindFirstChild("Gate")
        local back = gate and gate:FindFirstChild("Back")
        if back and back.CanCollide then
            return i -- this zone is locked, try to buy it
        end
    end
    return nil -- all zones unlocked
end

