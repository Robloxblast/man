local function getHighestUnlockedZone()
    local highest = 0

    for i = 1, 28 do
        local zone = ZonesFolder:FindFirstChild(tostring(i))

        if zone then
            local gate = zone:FindFirstChild("Gate")

            if gate then
                local back = gate:FindFirstChild("Back")

                if back and back:IsA("BasePart") then
                    if back.Transparency == 1 then
                        highest = i
                    end
                end
            end
        end
    end

    return highest
end

local function teleportToZone(zoneNumber)
    local zone = ZonesFolder:FindFirstChild(tostring(zoneNumber))
    if not zone then return end

    local poi = zone:FindFirstChild("POI")
    if not poi then return end

    local spawnPart = poi:FindFirstChild("PlayerSpawn")
    if not spawnPart then return end

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")

    if hrp then
        hrp.CFrame = spawnPart.CFrame + Vector3.new(0, 5, 0)
    end
end

