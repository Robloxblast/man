local function unequipSlot(slot)  invRF:InvokeServer("requestUnequip", slot) end
local function equipSlime(id)     invRF:InvokeServer("requestEquip", id) end
local function unequipSlime(id)   invRF:InvokeServer("requestUnequip", id) end
local function equipBest()        invRF:InvokeServer("requestEquipBest") end

local function getSlimesFolder()
    for _, v in pairs(workspace:GetChildren()) do
        if v:FindFirstChild("Slimes") then return v.Slimes end
    end
end

local function isGUID(str)
    return str:match("^%.%x+%-%x+%-%x+%-%x+%-%x+$") ~= nil
end

local function formatName(raw)
    local stripped = raw:gsub("^InventorySlime_", ""):gsub("^%-", ""):gsub("^%.", "")
    return stripped:sub(1,1):upper() .. stripped:sub(2)
end

local function resolveGUID(guid)
    equipSlime(guid)
    task.wait(0.8)
    local slimesFolder = getSlimesFolder()
    if not slimesFolder then unequipSlime(guid) task.wait(0.3) return nil end
    local displayName = nil
    for _, obj in ipairs(slimesFolder:GetChildren()) do
        if obj.Name:sub(1, #guid) == guid then
            local billboard = obj:FindFirstChild("SlimeInfoBillboard")
            if billboard then
                local content = billboard:FindFirstChild("Content")
                if content then
                    local nameLabel = content:FindFirstChild("Name")
                    if nameLabel then displayName = nameLabel.Text end
                end
            end
            break
        end
    end
    unequipSlime(guid)
    task.wait(0.3)
    return displayName
end

local function getSlimeOptions()
    local tbl = {}
    for display, _ in pairs(slimeMap) do table.insert(tbl, display) end
    table.sort(tbl)
    return tbl
end

local function getSlimeOptionsWithAll()
    local tbl = {"All"}
    for display, _ in pairs(slimeMap) do table.insert(tbl, display) end
    table.sort(tbl, function(a, b)
        if a == "All" then return true end
        if b == "All" then return false end
        return a < b
    end)
    return tbl
end

local function getSlimeByText(text)
    local folder = getSlimesFolder()
    if not folder then return nil end
    local guid = slimeMap[text]
    if guid then
        for _, v in pairs(folder:GetChildren()) do
            if v.Name:sub(1, #guid) == guid then return v end
        end
    end
    for _, v in pairs(folder:GetChildren()) do
        local billboard = v:FindFirstChild("SlimeInfoBillboard")
        if billboard and billboard:FindFirstChild("Content") then
            local nameObj = billboard.Content:FindFirstChild("Name")
            if nameObj and nameObj:IsA("TextLabel") and nameObj.Text == text then return v end
        end
    end
end

