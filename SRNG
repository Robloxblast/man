local function getSlimesFolder()
    for _, v in pairs(workspace:GetChildren()) do
        if v:FindFirstChild("Slimes") then return v.Slimes end
    end
end

local function isGUID(str)
    return str:match("^%.%x+%-%x+%-%x+%-%x+%-%x+$") ~= nil
end

local function formatName(raw)
    local stripped = raw:gsub("^InventorySlime_", ""):gsub("^%-", ""):gsub("^%.", "")
    return stripped:sub(1,1):upper() .. stripped:sub(2)
end

local function resolveGUID(guid)
    equipSlime(guid)
    task.wait(0.8)
    local slimesFolder = getSlimesFolder()
    if not slimesFolder then unequipSlime(guid) task.wait(0.3) return nil end
    local displayName = nil
    for _, obj in ipairs(slimesFolder:GetChildren()) do
        if obj.Name:sub(1, #guid) == guid then
            local billboard = obj:FindFirstChild("SlimeInfoBillboard")
            if billboard then
                local content = billboard:FindFirstChild("Content")
                if content then
                    local nameLabel = content:FindFirstChild("Name")
                    if nameLabel then displayName = nameLabel.Text end
                end
            end
            break
        end
    end
    unequipSlime(guid)
    task.wait(0.3)
    return displayName
end

local function getSlimeOptions()
    local tbl = {}
    for display, _ in pairs(slimeMap) do table.insert(tbl, display) end
    table.sort(tbl)
    return tbl
end

local function getSlimeOptionsWithAll()
    local tbl = {"All"}
    for display, _ in pairs(slimeMap) do table.insert(tbl, display) end
    table.sort(tbl, function(a, b)
        if a == "All" then return true end
        if b == "All" then return false end
        return a < b
    end)
    return tbl
end

local function getSlimeByText(text)
    local folder = getSlimesFolder()
    if not folder then return nil end
    local guid = slimeMap[text]
    if guid then
        for _, v in pairs(folder:GetChildren()) do
            if v.Name:sub(1, #guid) == guid then return v end
        end
    end
    for _, v in pairs(folder:GetChildren()) do
        local billboard = v:FindFirstChild("SlimeInfoBillboard")
        if billboard and billboard:FindFirstChild("Content") then
            local nameObj = billboard.Content:FindFirstChild("Name")
            if nameObj and nameObj:IsA("TextLabel") and nameObj.Text == text then return v end
        end
    end
end

local SlimeDropdown, XPGiverDropdown, XPReceiverDropdown, ProtectedDropdown

local function refreshAllDropdowns()
    local opts    = getSlimeOptions()
    local optsAll = getSlimeOptionsWithAll()
    if #opts > 0 then
        SlimeDropdown:Refresh(opts)
        XPReceiverDropdown:Refresh(opts)
        ProtectedDropdown:Refresh(opts)
    end
    XPGiverDropdown:Refresh(optsAll)
end

-- ============================================================
-- SCANNER — also disables Auto Roll toggle
-- ============================================================

local function initSlimeSystem()
    if scanning then return end
    scanning = true

    -- disable auto roll toggle + stop thread
    AutoRollToggle:Set(false)
    autoRoll = false
    if rollThread then task.cancel(rollThread) rollThread = nil end

    Rayfield:Notify({ Title = "Slime Scanner", Content = "Disabling auto roll & clearing slots...", Duration = 4, Image = 4483362458 })
    settingsRE:FireServer("set", "autoRoll", false)
    task.wait(0.2)

    for slot = 1, 10 do unequipSlot(slot) end
    task.wait(0.3)

    local scrollFrame = user.PlayerGui.Root.Inventory.PageInventoryContent.SlimesPage.ScrollingFrame
    local options     = {}
    local guidQueue   = {}

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            local raw = child.Name:gsub("^InventorySlime_", "")
            if isGUID(raw) then
                if not slimeMap[raw] then table.insert(guidQueue, raw) end
            else
                local display = formatName(child.Name)
                if not slimeMap[display] then slimeMap[display] = raw end
                table.insert(options, display)
            end
        end
    end

    if #guidQueue > 0 then
        Rayfield:Notify({ Title = "Slime Scanner", Content = "Found " .. #guidQueue .. " unknown slime(s) — reading names. Please wait!", Duration = 5, Image = 4483362458 })
        for i, guid in ipairs(guidQueue) do
            Rayfield:Notify({ Title = "Reading Slime", Content = "Checking slime " .. i .. " of " .. #guidQueue .. "...", Duration = 2, Image = 4483362458 })
            local display = resolveGUID(guid)
            if display then
                slimeMap[display] = guid
                table.insert(options, display)
            end
        end
    end

    equipBest()
    task.wait(0.2)
    settingsRE:FireServer("set", "autoRoll", true)

    saveSlimeMap()
    refreshAllDropdowns()
    Rayfield:Notify({ Title = "Slime Scanner", Content = "Done! " .. #options .. " slime(s) found.", Duration = 4, Image = 4483362458 })
    scanning = false
end

