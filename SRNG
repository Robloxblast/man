local function initSlimeSystem()
    if scanning then return end
    scanning = true

    Rayfield:Notify({ Title = "Slime Scanner", Content = "Disabling auto roll & clearing slots...", Duration = 4, Image = 4483362458 })

    rs:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("leifstout_networker@0.3.1"):WaitForChild("networker"):WaitForChild("_remotes"):WaitForChild("SettingsService"):WaitForChild("RemoteEvent"):FireServer("set", "autoRoll", false)
    task.wait(0.2)

    for slot = 1, 10 do
        unequipSlot(slot)
    end
    task.wait(0.3)

    local scrollFrame = user.PlayerGui.Root.Inventory.PageInventoryContent.SlimesPage.ScrollingFrame
    local options = {}
    local guidQueue = {}

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            local raw = child.Name:gsub("^InventorySlime_", "")
            if isGUID(raw) then
                if not slimeMap[raw] then
                    table.insert(guidQueue, raw)
                end
            else
                local display = formatName(child.Name)
                if not slimeMap[display] then
                    slimeMap[display] = raw
                end
                table.insert(options, display)
            end
        end
    end

    if #guidQueue > 0 then
        Rayfield:Notify({ Title = "Slime Scanner", Content = "Found " .. #guidQueue .. " unknown slime(s) — reading names. Please wait!", Duration = 5, Image = 4483362458 })
        for i, guid in ipairs(guidQueue) do
            Rayfield:Notify({ Title = "Reading Slime", Content = "Checking slime " .. i .. " of " .. #guidQueue .. "...", Duration = 2, Image = 4483362458 })
            local display = resolveGUID(guid)
            if display then
                slimeMap[display] = guid
                table.insert(options, display)
            end
        end
    end

    equipBest()
    task.wait(0.2)

    rs:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("leifstout_networker@0.3.1"):WaitForChild("networker"):WaitForChild("_remotes"):WaitForChild("SettingsService"):WaitForChild("RemoteEvent"):FireServer("set", "autoRoll", true)

    saveSlimeMap()
    refreshAllDropdowns()
    Rayfield:Notify({ Title = "Slime Scanner", Content = "Done! " .. #options .. " slime(s) found.", Duration = 4, Image = 4483362458 })

    scanning = false
end

