-- ============================================================
-- SERVER HOP
-- ============================================================

local function serverHop()
    local ok, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true")
    end)
    if not ok then return false end

    local body = HttpService:JSONDecode(result)
    if not body or not body.data then return false end

    local servers = {}
    for _, v in ipairs(body.data) do
        if type(v) == "table" and v.playing and v.maxPlayers and v.playing < v.maxPlayers and v.id ~= JobId then
            table.insert(servers, v.id)
        end
    end

    if #servers > 0 then
        if queue_on_teleport then
            queue_on_teleport("loadstring(game:HttpGet('https://raw.githubusercontent.com/Robloxblast/man/refs/heads/main/SRNG'))()")
        end
        TeleportService:TeleportToPlaceInstance(PlaceId, servers[math.random(1, #servers)], player)
        return true
    else
        Rayfield:Notify({ Title = "Server Hop", Content = "No available servers found! Stopping.", Duration = 4, Image = 4483362458 })
        return false
    end
end

-- ============================================================
-- AUTO HOP FOR SERVER LUCK
-- ============================================================

local autoHop      = false
local hopThread    = nil
local CHECK_INTERVAL = 5

local function getLuckText()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local root = playerGui:FindFirstChild("Root")
    if not root then return nil end
    local ok, text = pcall(function()
        return root.BottomBarStats.StatsList.LuckStat.LuckHoverInfo.Background["Global Luck"].Value.TextLabel.Text
    end)
    if ok and type(text) == "string" then return text end
    return nil
end

local function hasServerLuck(text)
    if not text then return false end
    local multiplier = text:match("x(%d+)")
    return multiplier and tonumber(multiplier) >= 2
end

local function startAutoHop()
    hopThread = task.spawn(function()
        while autoHop do
            local text = getLuckText()
            if text then
                if hasServerLuck(text) then
                    Rayfield:Notify({ Title = "Server Luck Found!", Content = "Server luck active: " .. tostring(text) .. " — staying!", Duration = 4, Image = 4483362458 })
                    task.wait(CHECK_INTERVAL)
                else
                    Rayfield:Notify({ Title = "No Server Luck", Content = "Luck: " .. tostring(text) .. " — hopping...", Duration = 3, Image = 4483362458 })
                    task.wait(2)
                    local hopped = serverHop()
                    if not hopped then
                        autoHop = false
                        Rayfield:Notify({ Title = "Auto Hop", Content = "Stopped — no servers available.", Duration = 4, Image = 4483362458 })
                        return
                    end
                    return
                end
            else
                task.wait(1)
            end
        end
    end)
end

