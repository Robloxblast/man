-- KILL AURA
-- ============================================================

local killAura      = false
local killAuraThread = nil
local killAuraRange = 100
local killAuraDelay = 0.1

local function getEnemiesFolder()
    for _, v in ipairs(workspace:GetChildren()) do
        local e = v:FindFirstChild("Enemies")
        if e then return e end
    end
    return nil
end

local function getEnemies()
    local enemies = {}
    local enemiesFolder = getEnemiesFolder()
    if not enemiesFolder then return enemies end

    local char  = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")

    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        if myHRP then
            local ok, pos = pcall(function() return enemy:GetPivot().Position end)
            if ok and (pos - myHRP.Position).Magnitude <= killAuraRange then
                table.insert(enemies, enemy)
            elseif not ok then
                table.insert(enemies, enemy)
            end
        else
            table.insert(enemies, enemy)
        end
    end
    return enemies
end

local function startKillAura()
    killAuraThread = task.spawn(function()
        while killAura do
            local enemies = getEnemies()
            if #enemies > 0 then
                for _, enemy in ipairs(enemies) do
                    if not killAura then break end
                    task.spawn(function()
                        pcall(function()
                            SlimeGunRF:InvokeServer("tryFireSlimeGun", tonumber(enemy.Name))
                        end)
                    end)
                end
            end
            task.wait(killAuraDelay)
        end
    end)
end

