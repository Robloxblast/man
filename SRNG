}

local lootSet = {}
for _, name in ipairs(lootNames) do lootSet[name:lower()] = true end

local collecting    = false
local collectThread = nil

local function touchPart(part)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    firetouchinterest(hrp, part, 0)
    firetouchinterest(hrp, part, 1)
end

local function collectLoot()
    local lootFolder = workspace:FindFirstChild("Loot")
    if not lootFolder then return end

    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local originalCFrame = hrp.CFrame

    for _, child in ipairs(lootFolder:GetChildren()) do
        for _, item in ipairs(child:GetDescendants()) do
            if lootSet[item.Name:lower()] then
                if item:IsA("BasePart") then
                    local ti = item:FindFirstChildOfClass("TouchTransmitter") or item:FindFirstChild("TouchInterest")
                    if ti then touchPart(item) end
                end

                local function handlePrompt(prompt)
                    if not prompt or not prompt:IsA("ProximityPrompt") then return end
                    local worldPos
                    if item:IsA("Attachment") then
                        worldPos = item.WorldPosition
                    elseif item:IsA("BasePart") then
                        worldPos = item.Position
                    end
                    if worldPos then
                        hrp.CFrame = CFrame.new(worldPos + Vector3.new(0, 3, 0))
                        task.wait(0.05)
                        fireproximityprompt(prompt)

                        -- wait until the root/item is destroyed or timeout
                        local root = item.Parent
                        local elapsed = 0
                        while elapsed < 3 do
                            if not root or not root.Parent then break end
                            if not item or not item.Parent then break end
                            task.wait(0.05)
                            elapsed += 0.05
                        end

                        hrp.CFrame = originalCFrame
                    end
                end

                local att = item:FindFirstChild("Attachment") or item:FindFirstChild("attachment")
                if att then handlePrompt(att:FindFirstChildOfClass("ProximityPrompt")) end

                if item:IsA("Attachment") then
                    handlePrompt(item:FindFirstChildOfClass("ProximityPrompt"))
                end

                if item:IsA("BasePart") then
                    handlePrompt(item:FindFirstChildOfClass("ProximityPrompt"))
                end
            end
        end
    end

    hrp.CFrame = originalCFrame
end

