local function isProtected(display)
    for _, p in ipairs(protectedSlimes) do
        if p == display then return true end
    end
    return false
end

local function getGivers()
    local selected = Rayfield.Flags and Rayfield.Flags["xpgivers"] and Rayfield.Flags["xpgivers"].CurrentOption or {"All"}
    local useAll = false
    for _, v in ipairs(selected) do
        if v == "All" then useAll = true break end
    end

    local givers = {}
    if useAll then
        for display, id in pairs(slimeMap) do
            if not isProtected(display) then
                table.insert(givers, {display = display, id = id})
            end
        end
    else
        for _, display in ipairs(selected) do
            if not isProtected(display) and slimeMap[display] then
                table.insert(givers, {display = display, id = slimeMap[display]})
            end
        end
    end

    return givers
end

