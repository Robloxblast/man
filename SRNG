local function saveSlimeMap()
    local data = {}
    for display, id in pairs(slimeMap) do data[display] = id end
    pcall(function() writefile(saveFile, HttpService:JSONEncode(data)) end)
end

local function loadSlimeMap()
    local ok, content = pcall(readfile, saveFile)
    if not ok or not content or content == "" then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(content) end)
    if ok2 and type(data) == "table" then
        for display, id in pairs(data) do slimeMap[display] = id end
