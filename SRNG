local function triggerPrompt(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        fireproximityprompt(prompt)
    end
end

local function touchPart(part)
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    firetouchinterest(hrp, part, 0)
    firetouchinterest(hrp, part, 1)
end

local function collectLoot()
    local lootFolder = workspace:FindFirstChild("Loot")
    if not lootFolder then return end

    for _, child in ipairs(lootFolder:GetChildren()) do
        for _, item in ipairs(child:GetDescendants()) do
            if lootSet[item.Name:lower()] then
                if item:IsA("BasePart") then
                    local touchInterest = item:FindFirstChildOfClass("TouchTransmitter")
                        or item:FindFirstChild("TouchInterest")

                    if touchInterest then
                        touchPart(item)
                    end
                end

                local attachment = item:FindFirstChild("Attachment")
                    or item:FindFirstChild("attachment")

                if attachment and attachment:IsA("Attachment") then
                    local prompt = attachment:FindFirstChildOfClass("ProximityPrompt")
                    triggerPrompt(prompt)
                end

                if item:IsA("Attachment") then
                    local prompt = item:FindFirstChildOfClass("ProximityPrompt")
                    triggerPrompt(prompt)
                end
            end
        end
    end
end

