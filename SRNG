-- ========================
-- SERVER HOP FUNCTION
-- ========================
local function serverHop()
    local ok, result = pcall(function()
        return game:HttpGet(
            "https://games.roblox.com/v1/games/" ..
            PlaceId ..
            "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"
        )
    end)

    if not ok then return end

    local body = HttpService:JSONDecode(result)
    if not body or not body.data then return end

    local servers = {}

    for _, v in ipairs(body.data) do
        if type(v) == "table"
        and v.playing
        and v.maxPlayers
        and v.playing < v.maxPlayers
        and v.id ~= JobId then
            table.insert(servers, v.id)
        end
    end

    if #servers > 0 then
        if queue_on_teleport then
            queue_on_teleport("loadstring(game:HttpGet('https://raw.githubusercontent.com/Robloxblast/man/refs/heads/main/SRNG'))()")
        end
        TeleportService:TeleportToPlaceInstance(
            PlaceId,
            servers[math.random(1, #servers)],
            Players.LocalPlayer
        )
    else
        Rayfield:Notify({
            Title = "Server Hop",
            Content = "No available servers found!",
            Duration = 3,
            Image = 4483362458,
        })
    end
end

-- ========================
-- AUTO HOP LOGIC
-- ========================
local autoHop = false
local hopThread = nil
local CHECK_INTERVAL = 5 -- check every 3 seconds

local function getLuckText()
    local playerGui = Players.LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local root = playerGui:FindFirstChild("Root")
    if not root then return nil end
    local ok, text = pcall(function()
        return root.BottomBarStats.StatsList.LuckStat.LuckHoverInfo.Background["Global Luck"].Value.TextLabel.Text
    end)
    if ok and type(text) == "string" then return text end
    return nil
end

local function hasServerLuck(text)
    if not text then return false end
    -- look for x2 or higher (x2, x3, x5, x10 etc)
    local multiplier = text:match("x(%d+)")
    if multiplier and tonumber(multiplier) >= 2 then
        return true
    end
    return false
end

local function startAutoHop()
    hopThread = task.spawn(function()
        while autoHop do
            local text = getLuckText()
            if text then
                if hasServerLuck(text) then
                    Rayfield:Notify({
                        Title = "Server Luck Found!",
                        Content = "Server luck active: " .. tostring(text) .. " — staying!",
                        Duration = 4,
                        Image = 4483362458,
                    })
                    -- keep checking in case it changes
                    task.wait(CHECK_INTERVAL)
                else
                    Rayfield:Notify({
                        Title = "No Server Luck",
                        Content = "Luck: " .. tostring(text) .. " — hopping...",
                        Duration = 3,
                        Image = 4483362458,
                    })
                    task.wait(2)
                    serverHop()
                    return -- stop loop after hop
                end
            else
                -- GUI not loaded yet, wait
                task.wait(1)
            end
        end
    end)
end

