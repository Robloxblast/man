local function handleNewSlimeChild(child)
    task.wait(0.5)
    if not child:IsA("Frame") or scanning then return end
    local raw = child.Name:gsub("^InventorySlime_", "")

    local function logIfNeeded(display)
        if not loggingEnabled then return end
        task.spawn(function()
            local rarity = getSlimeRarityFromFrame(child)
            if not rarity then task.wait(1) rarity = getSlimeRarityFromWorkspace(display) end
            if rarity then
                local tier = getRarityTier(rarity)
                if tier and shouldLog(tier) then sendWebhook(display, rarity) end
            end
        end)
    end

    if isGUID(raw) then
        if slimeMap[raw] then return end
        scanning = true
        Rayfield:Notify({ Title = "New Slime Detected", Content = "Reading new slime name...", Duration = 3, Image = 4483362458 })
        local display = resolveGUID(raw)
        scanning = false
        if display and not slimeMap[display] then
            slimeMap[display] = raw
            saveSlimeMap()
            refreshAllDropdowns()
            Rayfield:Notify({ Title = "New Slime Added", Content = display .. " added to the list!", Duration = 3, Image = 4483362458 })
            logIfNeeded(display)
        end
    else
        local display = formatName(child.Name)
        if slimeMap[display] then return end
        slimeMap[display] = raw
        saveSlimeMap()
        refreshAllDropdowns()
        Rayfield:Notify({ Title = "New Slime Added", Content = display .. " added to the list!", Duration = 3, Image = 4483362458 })
        logIfNeeded(display)
    end
end

