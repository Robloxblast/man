local lootNames = {
    "Root", "cherries", "pizza", "apple", "carrot", "drumstick",
    "chicken", "watermelon", "banana", "avocado", "broccoli",
    "bigDice", "coinpotion", "hugeDice", "invertedDice", "luckPotion",
