local webhookUrl      = ""
local loggingEnabled  = false
local selectedRarities = {}
local rarityOrder     = {"K", "M", "B", "T", "Qd", "Qn", "Sx"}

local function getRarityTier(text)
    for _, suffix in ipairs(rarityOrder) do
        if text:find(suffix) then return suffix end
    end
    return nil
end

local function shouldLog(tier)
    if #selectedRarities == 0 then return false end
    for _, r in ipairs(selectedRarities) do
        if r == tier then return true end
    end
    return false
end

local function getSlimeRarity(frame)
    local btn = frame:FindFirstChild("SlimeButton")
    if not btn then return nil end
    local frameCount = 0
    for _, child in ipairs(btn:GetChildren()) do
        if child:IsA("Frame") and child.Name == "TextLabelFrame" then
            frameCount += 1
            if frameCount == 2 then
                local tl = child:FindFirstChildOfClass("TextLabel")
                if tl then
                    -- strip ALL whitespace and non-breaking spaces
                    return tl.Text:gsub("%s", ""):gsub("\226\128\139", ""):gsub("\194\160", "")
                end
            end
        end
    end
    return nil
end

local function normalizeRarity(s)
    return s:gsub("%s", ""):gsub("\226\128\139", ""):gsub("\194\160", "")
end

local function findIngredients(rarities)
    local scroll = player.PlayerGui.Root.Inventory.PageInventoryContent.SlimesPage.ScrollingFrame
    local ids = {}
    local usedFrames = {}

    for _, target in ipairs(rarities) do
        local normTarget = normalizeRarity(target)
        local found = false
        for _, frame in ipairs(scroll:GetChildren()) do
            if frame:IsA("Frame") and not usedFrames[frame.Name] then
                local rarity = getSlimeRarity(frame)
                if rarity and normalizeRarity(rarity) == normTarget then
                    table.insert(ids, frame.Name:gsub("^InventorySlime_", ""))
                    usedFrames[frame.Name] = true
                    found = true
                    break
                end
            end
        end
        if not found then
            return nil, target  -- return which rarity was missing
        end
    end

    return ids, nil
end

local function getSlimeRarityFromWorkspace(displayName)
    local folder = getSlimesFolder()
    if not folder then return nil end
    for _, obj in ipairs(folder:GetChildren()) do
        local billboard = obj:FindFirstChild("SlimeInfoBillboard")
        if billboard then
            local content = billboard:FindFirstChild("Content")
            if content then
                local nameLabel = content:FindFirstChild("Name")
                if nameLabel and nameLabel.Text == displayName then
                    local odds = content:FindFirstChild("Odds")
                    if odds then
                        local tl = odds:FindFirstChildOfClass("TextLabel")
                        if tl then return tl.Text end
                    end
                end
            end
        end
    end
    return nil
end

local function sendWebhook(slimeName, rarity)
    if webhookUrl == "" then return end
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = "🟢 New Slime Rolled!",
                    color = 0x00ff99,
                    fields = {
                        { name = "Slime", value = slimeName, inline = true },
                        { name = "Rarity", value = rarity, inline = true },
                    },
                    footer = { text = "Xarxynth Hub • Slime Logger" }
                }}
            })
        })
    end)
end

