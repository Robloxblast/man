-- =============================================
-- HELPER — safe value fetch from LocalPlayer
-- =============================================

local function getVal(name)
    local vals = localPlayer:FindFirstChild("Values")
    if not vals then return nil end
    return vals:FindFirstChild(name)
end

local function getPlayerVal(plr, name)
    local vals = plr:FindFirstChild("Values")
    if not vals then return nil end
    return vals:FindFirstChild(name)
end

-- =============================================
-- AUTO GREEN
-- hookmetamethod override:
-- Intercepts Shoot FireServer and forces args
-- to { false, -1, false } for guaranteed green.
-- =============================================

local hookSupported = typeof(hookmetamethod) == "function"

if not hookSupported then
    Rayfield:Notify({
        Title = "Auto Green Unavailable",
        Content = "Your executor doesn't support hookmetamethod so Auto Green has been hidden. All other features work normally.",
        Duration = 8,
        Image = 4483362458,
    })
else
    local ToggleEnabled = false

    Tab:CreateToggle({
        Name = "Auto Green",
        CurrentValue = false,
        Flag = "AutoGreenToggle",
        Callback = function(Value)
            ToggleEnabled = Value
        end,
    })

    local old
    old = hookmetamethod(game, "__namecall", function(self, ...)
        local args = {...}
        local method = getnamecallmethod()
        if ToggleEnabled and method == "FireServer" and self.Name == "Shoot" then
            args[2] = -1
            return old(self, unpack(args))
        end
        return old(self, ...)
    end)
end

-- =============================================
-- DRIBBLE GLIDE
-- Reads localPlayer.Values.Dribbling (BoolValue)
-- TranslateBy + velocity fallback for crossovers
-- =============================================

local glideEnabled = false
local glideSpeed   = 10

Tab:CreateToggle({
    Name = "Dribble Glide",
    CurrentValue = false,
    Flag = "DribbleGlide",
    Callback = function(v)
        glideEnabled = v
    end,
})

Tab:CreateSlider({
    Name = "Glide Speed",
    Range = {1, 100},
    Increment = 0.1,
    Suffix = "",
    CurrentValue = glideSpeed,
    Flag = "GlideSpeed",
    Callback = function(v)
        glideSpeed = v
    end,
})

RunService.Heartbeat:Connect(function(delta)
    if not glideEnabled then return end

    local dribbling = getVal("Dribbling")
    if not dribbling or not dribbling.Value then return end

    local c = localPlayer.Character
    if not c then return end

    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    local hrpPart = c:FindFirstChild("HumanoidRootPart")
    if not hrpPart then return end

    local moveDir = hum.MoveDirection

    if moveDir.Magnitude > 0 then
        c:TranslateBy(moveDir * glideSpeed * delta * 10)
    else
        local vel     = hrpPart.Velocity
        local flatVel = Vector3.new(vel.X, 0, vel.Z)
        if flatVel.Magnitude > 0.5 then
            c:TranslateBy(flatVel.Unit * glideSpeed * delta * 10)
        end
    end
end)

-- =============================================
-- AUTO BLOCK
-- Checks nearest player's Values.Shooting
-- or Values.Dunking BoolValue.
-- Fires Space when either is true.
-- =============================================

local autoBlockEnabled  = false
local autoBlockMaxStuds = 20
local blockTeamCheck    = false

Tab:CreateToggle({
    Name = "Auto Block",
    CurrentValue = false,
    Flag = "AutoBlock",
    Callback = function(v)
        autoBlockEnabled = v
    end,
})

Tab:CreateSlider({
    Name = "Block Max Distance",
    Range = {1, 50},
    Increment = 1,
    Suffix = " studs",
    CurrentValue = autoBlockMaxStuds,
    Flag = "BlockDistance",
    Callback = function(v)
        autoBlockMaxStuds = v
    end,
})

Tab:CreateToggle({
    Name = "Block Team Check",
    CurrentValue = false,
    Flag = "BlockTeamCheck",
    Callback = function(v)
        blockTeamCheck = v
    end,
})

RunService.Heartbeat:Connect(function()
    if not autoBlockEnabled then return end

    local myHRP           = hrp
    local closestPlayer   = nil
    local closestDistance = math.huge

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end
        if not plr.Character then continue end
        if blockTeamCheck and plr.Team == localPlayer.Team then continue end

        local plrHRP = plr.Character:FindFirstChild("HumanoidRootPart")
        if not plrHRP then continue end

        local shooting = getPlayerVal(plr, "Shooting")
        local dunking  = getPlayerVal(plr, "Dunking")

        local isShooting = (shooting and shooting.Value) or (dunking and dunking.Value)
        if not isShooting then continue end

        local dist = (myHRP.Position - plrHRP.Position).Magnitude
        if dist < closestDistance and dist <= autoBlockMaxStuds then
            closestDistance = dist
            closestPlayer   = plr
        end
    end

    if closestPlayer then
        VirtualInput:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
        task.wait(0.05)
        VirtualInput:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
    end
end)

