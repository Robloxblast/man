local antiStealEnabled  = false
local antiStealMaxStuds = 15
local antiStealCooldown = 0.5
local lastTrigger       = 0

Tab:CreateToggle({
    Name = "Anti Steal",
    CurrentValue = false,
    Flag = "AntiSteal",
    Callback = function(v)
        antiStealEnabled = v
    end,
})

Tab:CreateSlider({
