-- Ball Mag Toggle
local BallMagToggle = Tab:CreateToggle({
    Name = "Ball Mag",
    CurrentValue = false,
    Flag = "BallMag",
    Callback = function(v)
        ballMagEnabled = v

        -- restore original sizes and destroy spheres if disabled
        if not ballMagEnabled then
            local ballsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Balls")
            if ballsFolder then
                for _, ball in pairs(ballsFolder:GetChildren()) do
                    if ball:IsA("BasePart") and ball.Name == "Ball" then
                        if originalSizes[ball] then
                            ball.Size = originalSizes[ball]
                        end
                        if spheres[ball] then
                            spheres[ball]:Destroy()
                            spheres[ball] = nil
                        end
                    end
                end
            end
        end
    end,
})

