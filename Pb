user.InputBegan:Connect(function(i, g)
    if g or not enabled then return end

    -- Shooting (E / X / Square)
    if (i.KeyCode == Enum.KeyCode.E or
        i.KeyCode == Enum.KeyCode.ButtonX) and not holding then
        holding = true
        started = false
        dribbleHeld = isDribbling()
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    end

    -- Dunking (Space / Y / Triangle)
    if (i.KeyCode == Enum.KeyCode.Space or
        i.KeyCode == Enum.KeyCode.ButtonY) and not holdingDunk then
        holdingDunk = true
        startedDunk = false
        dribbleHeldDunk = isDribbling()
        vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
    end
end)

rs.Heartbeat:Connect(function()
    -- Shooting logic
    if enabled and holding and not started then
        if bar.Visible and not isDribbling() then
            started = true
            local actualDelay = dribbleHeld and offDribbleDelay or delay
            dribbleHeld = false

            task.delay(actualDelay, function()
                if holding then
                    vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    holding = false
                    started = false
                end
            end)
        end
    end

    -- Dunking logic
    if enabled and holdingDunk and not startedDunk then
        if bar.Visible and not isDribbling() then
            startedDunk = true
            local actualDelay = dribbleHeldDunk and offdribbledelay2 or delay2
            dribbleHeldDunk = false

            task.delay(actualDelay, function()
                if holdingDunk then
                    vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    holdingDunk = false
                    startedDunk = false
                end
            end)
        end
    end
end)

