RunService.Heartbeat:Connect(function()
    if not ballMagEnabled then return end

    local ballsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Balls")
    if not ballsFolder then return end

    for _, ball in pairs(ballsFolder:GetChildren()) do
        if ball:IsA("BasePart") and ball.Name == "Ball" then
            -- store original size if not already stored
            if not originalSizes[ball] then
                originalSizes[ball] = ball.Size
            end

            -- update size
            ball.Size = Vector3.new(ballSize, ballSize, ballSize)

            -- handle visualizer sphere
            if visualizerEnabled then
                if not spheres[ball] then
                    local sphere = Instance.new("SphereHandleAdornment")
                    sphere.Adornee = ball
                    sphere.Radius = ball.Size.X / 2
                    sphere.Color3 = Color3.fromRGB(255, 0, 0)
                    sphere.Transparency = visualizerTransparency
                    sphere.AlwaysOnTop = true
                    sphere.Parent = ball
                    spheres[ball] = sphere
                else
                    local sphere = spheres[ball]
                    sphere.Radius = ball.Size.X / 2
                    sphere.Transparency = visualizerTransparency
                end
            elseif spheres[ball] then
                spheres[ball]:Destroy()
                spheres[ball] = nil
            end
        end
    end
end)


