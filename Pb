local function GetClosestPlayer()
    local closest
    for _, v in pairs(players:GetPlayers()) do
        if v ~= plr and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            if not TeamCheck or (TeamCheck and plr.Team ~= v.Team) then
                local dist = (plr.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = v
                end
            end
        end
    end
    return closest
end

rs.RenderStepped:Connect(function()
    if not ToggleValue then return end
    local target = GetClosestPlayer()
    if target and target.Character then
        for _, track in pairs(target.Character.Humanoid:GetPlayingAnimationTracks()) do
            local animId = tonumber(track.Animation.AnimationId:match("%d+"))
            if table.find(AnimIds, animId) then
                local key = target.UserId .. "_" .. track.Animation.AnimationId
                if not TriggeredAnimations[key] then
                    TriggeredAnimations[key] = true
                    task.spawn(function()
                        task.wait(SliderDelay)
                        vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                        vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                    end)
                end
            else
                -- Remove from triggered if animation no longer playing
                local key = target.UserId .. "_" .. track.Animation.AnimationId
                TriggeredAnimations[key] = nil
            end
        end
    end
end)


