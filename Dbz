local toggle = false
local currentTrainingName = nil

local function fireButton(btn)
    for _,v in pairs(getconnections(btn.MouseButton1Click)) do
        v:Fire()
    end
end

local function getBestTraining()
    local bestIndex = 0
    local bestFrame = nil
    local bestButton = nil
    local bestName = nil

    for _, frame in pairs(scrollingFrame:GetChildren()) do
        if frame:IsA("Frame") then
            local textLabel = frame:FindFirstChildWhichIsA("TextLabel")
            local button = frame:FindFirstChildWhichIsA("TextButton")
            if textLabel and button then
                local index = table.find(order, textLabel.Text)
                if index and index > bestIndex then
                    bestIndex = index
                    bestFrame = frame
                    bestButton = button
                    bestName = textLabel.Text
                end
            end
        end
    end

    return bestName, bestButton
end

local function switchTraining()
    local bestName, bestButton = getBestTraining()
    if bestName and bestName ~= currentTrainingName then
        currentTrainingName = bestName
        fireButton(bestButton)
    end
end

